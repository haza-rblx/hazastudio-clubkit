--!nocheck
-- Kumpulkan / unpack semua instance Club Kit ke struktur package terstandar.

local CollectionService = game:GetService("CollectionService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local StarterGui = game:GetService("StarterGui")
local StarterPlayer = game:GetService("StarterPlayer")

local Manifest = require(script.Parent.ClubKitManifest)

local PackagerCore = {}

export type ExportOptions = {
	includeConfig: boolean,
	includeSecrets: boolean,
}

export type UnpackOptions = {
	replaceExisting: boolean,
	keepBuyerConfig: boolean,
	keepBuyerSecrets: boolean,
}

export type CollectReport = {
	ok: { string },
	missing: { string },
	warnings: { string },
	instanceCount: number,
}

export type UnpackReport = {
	ok: { string },
	skipped: { string },
	replaced: { string },
	missing: { string },
	warnings: { string },
}

local function getService(serviceName: string): Instance?
	if serviceName == "StarterPlayerScripts" then
		return StarterPlayer:FindFirstChild("StarterPlayerScripts")
	end
	if serviceName == "Workspace" then
		return workspace
	end

	local ok, svc = pcall(function()
		return game:GetService(serviceName)
	end)
	if ok and svc then
		return svc
	end
	return nil
end

local function ensureServiceFolder(packageRoot: Folder, serviceName: string): Folder
	local existing = packageRoot:FindFirstChild(serviceName)
	if existing and existing:IsA("Folder") then
		return existing
	end
	if existing then
		existing:Destroy()
	end
	local folder = Instance.new("Folder")
	folder.Name = serviceName
	folder.Parent = packageRoot
	return folder
end

local function countDescendants(root: Instance): number
	local n = 1
	for _ in root:GetDescendants() do
		n += 1
	end
	return n
end

local function logOk(report: CollectReport, line: string, inst: Instance?)
	table.insert(report.ok, line)
	if inst then
		report.instanceCount += countDescendants(inst)
	end
end

local function logMissing(report: CollectReport, line: string)
	table.insert(report.missing, line)
end

local function logWarn(report: CollectReport | UnpackReport, line: string)
	table.insert(report.warnings, line)
end

local function cloneInto(parent: Folder, source: Instance, destName: string?): Instance
	local clone = source:Clone()
	clone.Name = destName or source.Name
	clone.Parent = parent
	return clone
end

local function findWorkspaceModelRoot(name: string): Instance?
	local hit = workspace:FindFirstChild(name, true)
	if not hit then
		return nil
	end
	if hit:IsA("Model") then
		return hit
	end
	local ancestor = hit:FindFirstAncestorOfClass("Model")
	if ancestor then
		return ancestor
	end
	return hit
end

local function verifyKitFingerprint(): (boolean, string?)
	local kitFolder = ReplicatedStorage:FindFirstChild("Hazastudio_ClubKit")
	if not kitFolder then
		return false, "Hazastudio_ClubKit tidak ditemukan di ReplicatedStorage"
	end
	local kitProduct = kitFolder:FindFirstChild("KitProduct")
	if not kitProduct or not kitProduct:IsA("ModuleScript") then
		return false, "KitProduct tidak ditemukan"
	end
	local ok, product = pcall(require, kitProduct)
	if not ok or type(product) ~= "table" then
		return false, "KitProduct gagal di-require"
	end
	if product.ProductId ~= Manifest.PRODUCT_ID then
		return false, ("ProductId tidak cocok (harus %s)"):format(Manifest.PRODUCT_ID)
	end
	return true, product.KitVersion
end

local function writeManifestModule(packageRoot: Folder, version: string?, exportOptions: ExportOptions)
	local old = packageRoot:FindFirstChild(Manifest.MANIFEST_NAME)
	if old then
		old:Destroy()
	end

	local lines = {
		"-- Generated by Hazastudio Club Kit Packager. Jangan edit manual.",
		"return {",
		('\tproductId = "%s",'):format(Manifest.PRODUCT_ID),
		('\tkitVersion = "%s",'):format(version or Manifest.KIT_VERSION),
		("\texportedAt = %d,"):format(os.time()),
		("\tincludeConfig = %s,"):format(tostring(exportOptions.includeConfig)),
		("\tincludeSecrets = %s,"):format(tostring(exportOptions.includeSecrets)),
		"}",
	}

	local mod = Instance.new("ModuleScript")
	mod.Name = Manifest.MANIFEST_NAME
	mod.Source = table.concat(lines, "\n")
	mod.Parent = packageRoot
end

local function readManifest(packageRoot: Instance): { [string]: any }?
	local mod = packageRoot:FindFirstChild(Manifest.MANIFEST_NAME)
	if mod and mod:IsA("ModuleScript") then
		local ok, data = pcall(require, mod)
		if ok and type(data) == "table" then
			return data
		end
	end
	return nil
end

function PackagerCore.collect(options: ExportOptions): (Folder?, CollectReport)
	local report: CollectReport = {
		ok = {},
		missing = {},
		warnings = {},
		instanceCount = 0,
	}

	local valid, versionOrErr = verifyKitFingerprint()
	if not valid then
		logWarn(report, versionOrErr :: string)
	end

	local old = ServerStorage:FindFirstChild(Manifest.PACKAGE_NAME)
	if old then
		old:Destroy()
	end

	local packageRoot = Instance.new("Folder")
	packageRoot.Name = Manifest.PACKAGE_NAME

	for _, target in ipairs(Manifest.SERVICE_ROOTS) do
		local svc = getService(target.service)
		local dest = ensureServiceFolder(packageRoot, target.service)
		if not svc then
			logMissing(report, ("service %s"):format(target.service))
			continue
		end
		local src = svc:FindFirstChild(target.name)
		if not src then
			logMissing(report, ("%s/%s"):format(target.service, target.name))
			continue
		end
		local clone = cloneInto(dest, src)
		logOk(report, ("%s/%s [%d instances]"):format(target.service, target.name, countDescendants(clone)), clone)
	end

	for _, target in ipairs(Manifest.OPTIONAL_ROOTS) do
		local include = (target.key == "config" and options.includeConfig)
			or (target.key == "secrets" and options.includeSecrets)
		if not include then
			continue
		end
		local svc = getService(target.service)
		local dest = ensureServiceFolder(packageRoot, target.service)
		if not svc then
			logMissing(report, ("service %s"):format(target.service))
			continue
		end
		local src = svc:FindFirstChild(target.name)
		if not src then
			logMissing(report, ("%s/%s"):format(target.service, target.name))
			continue
		end
		local clone = cloneInto(dest, src)
		logOk(report, ("%s/%s [%d instances]"):format(target.service, target.name, countDescendants(clone)), clone)
	end

	-- ReplicatedStorage / WorldEffects (folder atau children terpisah).
	local rsFolder = ensureServiceFolder(packageRoot, "ReplicatedStorage")
	local worldEffects = ReplicatedStorage:FindFirstChild("WorldEffects")
	if worldEffects then
		local clone = cloneInto(rsFolder, worldEffects)
		logOk(report, ("ReplicatedStorage/WorldEffects [%d instances]"):format(countDescendants(clone)), clone)
	else
		local wrapper = Instance.new("Folder")
		wrapper.Name = "WorldEffects"
		wrapper.Parent = rsFolder
		local foundAny = false
		for _, effectName in ipairs(Manifest.WORLD_EFFECTS) do
			local src = ReplicatedStorage:FindFirstChild(effectName)
			if src then
				cloneInto(wrapper, src)
				foundAny = true
				logOk(report, ("ReplicatedStorage/%s"):format(effectName), src)
			else
				logMissing(report, ("ReplicatedStorage/%s"):format(effectName))
			end
		end
		if not foundAny then
			wrapper:Destroy()
		end
	end

	-- StarterGui
	local sgFolder = ensureServiceFolder(packageRoot, "StarterGui")
	local guiSeen: { [string]: boolean } = {}
	for _, guiName in ipairs(Manifest.STARTER_GUI_EXACT) do
		if guiSeen[guiName] then
			continue
		end
		local src = StarterGui:FindFirstChild(guiName)
		if src then
			guiSeen[guiName] = true
			local clone = cloneInto(sgFolder, src)
			logOk(report, ("StarterGui/%s"):format(guiName), clone)
		end
	end
	for _, child in ipairs(StarterGui:GetChildren()) do
		if child:IsA("ScreenGui") and string.match(child.Name, "^%d%d%-") and not guiSeen[child.Name] then
			guiSeen[child.Name] = true
			local clone = cloneInto(sgFolder, child)
			logOk(report, ("StarterGui/%s (auto)"):format(child.Name), clone)
		end
	end

	-- ServerStorage
	local ssFolder = ensureServiceFolder(packageRoot, "ServerStorage")
	for _, name in ipairs(Manifest.SERVER_STORAGE_EXACT) do
		local src = ServerStorage:FindFirstChild(name)
		if src then
			local clone = cloneInto(ssFolder, src)
			logOk(report, ("ServerStorage/%s [%d instances]"):format(name, countDescendants(clone)), clone)
		else
			logMissing(report, ("ServerStorage/%s"):format(name))
		end
	end

	-- Workspace
	local wsFolder = ensureServiceFolder(packageRoot, "Workspace")
	for _, name in ipairs(Manifest.WORKSPACE_EXACT) do
		local src = findWorkspaceModelRoot(name)
		if src then
			local clone = cloneInto(wsFolder, src)
			logOk(report, ("Workspace/%s"):format(name), clone)
		else
			logMissing(report, ("Workspace/%s"):format(name))
		end
	end
	for _, name in ipairs(Manifest.WORKSPACE_MULTI) do
		local found = false
		local counter = 0
		for _, descendant in ipairs(workspace:GetDescendants()) do
			if descendant.Name == name then
				found = true
				counter += 1
				local destName = if counter == 1 then name else ("%s__%d"):format(name, counter)
				local clone = cloneInto(wsFolder, descendant, destName)
				logOk(report, ("Workspace/%s @ %s"):format(destName, descendant:GetFullName()), clone)
			end
		end
		if not found then
			logMissing(report, ("Workspace/%s"):format(name))
		end
	end

	-- Bersihkan folder service kosong.
	for _, child in ipairs(packageRoot:GetChildren()) do
		if child:IsA("Folder") and #child:GetChildren() == 0 and child.Name ~= Manifest.MANIFEST_NAME then
			child:Destroy()
		end
	end

	writeManifestModule(packageRoot, if valid then versionOrErr else nil, options)
	packageRoot.Parent = ServerStorage

	return packageRoot, report
end

function PackagerCore.findPackageRoot(instances: { Instance }): Instance?
	for _, inst in ipairs(instances) do
		if inst.Name == Manifest.PACKAGE_NAME then
			return inst
		end
	end
	for _, inst in ipairs(instances) do
		if inst:FindFirstChild(Manifest.MANIFEST_NAME) then
			return inst
		end
	end
	for _, inst in ipairs(instances) do
		if inst:IsA("Folder") and inst:FindFirstChild("ReplicatedStorage") and inst:FindFirstChild("ServerScriptService") then
			return inst
		end
	end
	return instances[1]
end

local function shouldPreserveOnUnpack(instanceName: string, serviceName: string, options: UnpackOptions): boolean
	if options.keepBuyerConfig and serviceName == "ReplicatedStorage" and instanceName == "Hazastudio_ClubKitConfig" then
		return true
	end
	if options.keepBuyerSecrets and serviceName == "ServerScriptService" and instanceName == "Hazastudio_ClubKitSecrets" then
		return true
	end
	return false
end

local function isWorkspaceMultiPackedName(name: string): boolean
	for _, base in ipairs(Manifest.WORKSPACE_MULTI) do
		if name == base or string.match(name, "^" .. base .. "__%d+$") then
			return true
		end
	end
	return false
end

local function placeChild(
	targetService: Instance,
	child: Instance,
	serviceName: string,
	options: UnpackOptions,
	report: UnpackReport
)
	local allowDuplicate = serviceName == "Workspace" and isWorkspaceMultiPackedName(child.Name)

	if shouldPreserveOnUnpack(child.Name, serviceName, options) then
		if targetService:FindFirstChild(child.Name) then
			table.insert(report.skipped, ("%s/%s (buyer preserved)"):format(serviceName, child.Name))
			return
		end
	end

	if not allowDuplicate then
		local existing = targetService:FindFirstChild(child.Name)
		if existing then
			if not options.replaceExisting then
				table.insert(report.skipped, ("%s/%s (already exists)"):format(serviceName, child.Name))
				return
			end
			existing:Destroy()
			table.insert(report.replaced, ("%s/%s"):format(serviceName, child.Name))
		end
	end

	local clone = child:Clone()

	-- Workspace multi-instance: kembalikan nama asli (RunningText__2 -> RunningText).
	if serviceName == "Workspace" then
		local baseName = string.match(child.Name, "^(.+)__%d+$")
		if baseName then
			clone.Name = baseName
		end
	end

	clone.Parent = targetService
	table.insert(report.ok, ("%s/%s"):format(serviceName, clone.Name))
end

function PackagerCore.unpack(packageRoot: Instance, options: UnpackOptions): UnpackReport
	local report: UnpackReport = {
		ok = {},
		skipped = {},
		replaced = {},
		missing = {},
		warnings = {},
	}

	local meta = readManifest(packageRoot)
	if meta and meta.productId and meta.productId ~= Manifest.PRODUCT_ID then
		logWarn(report, ("ProductId manifest tidak cocok: %s"):format(tostring(meta.productId)))
	end

	local serviceNames = {
		"ReplicatedFirst",
		"ReplicatedStorage",
		"ServerScriptService",
		"StarterPlayerScripts",
		"StarterGui",
		"ServerStorage",
		"Workspace",
	}

	for _, serviceName in ipairs(serviceNames) do
		local bucket = packageRoot:FindFirstChild(serviceName)
		if not bucket or not bucket:IsA("Folder") then
			continue
		end
		local targetService = getService(serviceName)
		if not targetService then
			table.insert(report.missing, ("service %s"):format(serviceName))
			continue
		end
		for _, child in ipairs(bucket:GetChildren()) do
			placeChild(targetService, child, serviceName, options, report)
		end
	end

	-- Pastikan tag donation display root ikut (CollectionService tags tersimpan di rbxm).
	local displayTag = "DonationDisplayRoot"
	for _, tagName in ipairs(Manifest.WORKSPACE_MULTI) do
		for _, inst in ipairs(workspace:GetDescendants()) do
			if inst.Name == tagName and not CollectionService:HasTag(inst, displayTag) then
				CollectionService:AddTag(inst, displayTag)
				table.insert(report.ok, ("Tagged %s"):format(inst:GetFullName()))
			end
		end
	end

	return report
end

function PackagerCore.printCollectReport(report: CollectReport)
	print("==================================================")
	print("[ClubKitPackager] EXPORT")
	print(("  OK: %d | Missing: %d | Warnings: %d | ~%d instances"):format(
		#report.ok,
		#report.missing,
		#report.warnings,
		report.instanceCount
	))
	for _, line in ipairs(report.ok) do
		print("   + " .. line)
	end
	for _, line in ipairs(report.missing) do
		warn("   - MISSING: " .. line)
	end
	for _, line in ipairs(report.warnings) do
		warn("   ! " .. line)
	end
	print("==================================================")
end

function PackagerCore.printUnpackReport(report: UnpackReport)
	print("==================================================")
	print("[ClubKitPackager] UNPACK")
	print(("  Placed: %d | Replaced: %d | Skipped: %d | Missing svc: %d"):format(
		#report.ok,
		#report.replaced,
		#report.skipped,
		#report.missing
	))
	for _, line in ipairs(report.replaced) do
		print("   ~ replaced " .. line)
	end
	for _, line in ipairs(report.skipped) do
		print("   = skipped " .. line)
	end
	for _, line in ipairs(report.missing) do
		warn("   - " .. line)
	end
	for _, line in ipairs(report.warnings) do
		warn("   ! " .. line)
	end
	print("==================================================")
end

return PackagerCore
